* ===== Graficas del caso nominal (tt, 27C) =====
echo ""
echo "Generando graficas del caso nominal (tt, 27C)..."
source schmitt_circuit_tt.cir
alterparam ttemp = 27
reset
tran 2n 110u
write schmitt_nominal.raw
echo "Si corriste SIN -b: cierra ambas ventanas de grafica para terminar."
plot vout vs vin
plot vout vin

.endc

.end
